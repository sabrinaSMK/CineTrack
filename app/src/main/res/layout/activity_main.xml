<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black_cinema">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="390dp"
            android:layout_height="270dp"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="20dp"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:src="@drawable/logo_cinetrack" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_filme"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tvTotalFilmes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎬 Filmes cadastrados: 0"
                android:textColor="@color/white"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/tvMediaNotas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⭐ Avaliação média: Sem avaliações"
                android:textColor="@color/white"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/tvAssistidos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✅ Assistidos: 0"
                android:textColor="@color/white"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/tvQueroAssistir"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🕒 Quero assistir: 0"
                android:textColor="@color/white"
                android:textSize="16sp"/>

        </LinearLayout>

        <EditText
            android:id="@+id/etTitulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:hint="Título do Filme"
            android:textColor="@color/white"
            android:textColorHint="@color/light_gray"
            android:background="@drawable/edittext_bg"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etGenero"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:hint="Gênero"
            android:textColor="@color/white"
            android:textColorHint="@color/light_gray"
            android:background="@drawable/edittext_bg"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Avaliação"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:layout_marginBottom="6dp"/>

        <RatingBar
            android:id="@+id/ratingNota"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:numStars="5"
            android:stepSize="1"
            android:rating="0"
            android:layout_marginBottom="12dp"/>

        <Spinner
            android:id="@+id/spStatus"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/edittext_bg"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etComentario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:hint="Comentário"
            android:textColor="@color/white"
            android:textColorHint="@color/light_gray"
            android:background="@drawable/edittext_bg"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnSalvar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Salvar Filme"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:backgroundTint="#2196F3"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnVerFilmes"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Ver Filmes Salvos"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:backgroundTint="#2196F3"/>

    </LinearLayout>

</ScrollView>